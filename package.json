{
  "name": "devboard",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "zip": "npm run build && cp dist/index.html docs/app.html && cp README.txt dist/ && cd dist && zip -r ../devboard-itchio.zip index.html stickers favicon.ico README.txt && echo '✓ devboard-itchio.zip ready'",
    "release:html": "npm run zip && butler push devboard-itchio.zip mischa/devboard:html && butler push devboard-itchio.zip mischa/devboard:html-download",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "tauri:icon": "tauri icon public/favicon.ico"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "konva": "^9.3.6",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
